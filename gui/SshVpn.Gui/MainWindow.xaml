<Window x:Class="SshVpn.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SSH VPN"
        Width="760"
        Height="650"
        MinWidth="620"
        MinHeight="540"
        WindowStartupLocation="CenterScreen"
        WindowState="Normal"
        ShowInTaskbar="True"
        Background="{StaticResource PageBrush}"
        FontFamily="Segoe UI"
        Closing="Window_Closing"
        StateChanged="Window_StateChanged">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="28,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="SSH VPN" FontSize="26" FontWeight="SemiBold" />
                    <TextBlock Text="便携式 SSH 代理" Margin="0,4,0,0" FontSize="13" Foreground="{StaticResource MutedBrush}" />
                </StackPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Ellipse x:Name="StatusDot" Width="10" Height="10" Fill="#8A969C" Margin="0,0,9,0" />
                        <TextBlock x:Name="StatusText" AutomationProperties.AutomationId="StatusText" Text="未连接" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock x:Name="EndpointText" Text="SOCKS5 127.0.0.1:1080" Margin="0,5,0,0" FontSize="12" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Right" />
                </StackPanel>
            </Grid>
        </Border>

        <TabControl x:Name="MainTabs" Grid.Row="1" Margin="24,18,24,14" Background="Transparent" BorderBrush="{StaticResource BorderBrush}">
            <TabItem Header="连接">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="26,24,26,28" MaxWidth="620" HorizontalAlignment="Stretch">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="连接设置" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,20" />

                        <TextBlock Grid.Row="1" Text="服务器地址" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,7" />
                        <TextBox x:Name="ServerAddressBox" AutomationProperties.AutomationId="ServerAddressBox" Grid.Row="2" Margin="0,0,0,16" ToolTip="域名、IP 或 主机:端口" />

                        <Grid Grid.Row="3" Margin="0,0,0,7">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="150" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="用户名" FontSize="13" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="代理端口" FontSize="13" FontWeight="SemiBold" Margin="14,0,0,0" />
                        </Grid>
                        <Grid Grid.Row="4" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="150" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="UsernameBox" AutomationProperties.AutomationId="UsernameBox" />
                            <TextBox x:Name="ProxyPortBox" AutomationProperties.AutomationId="ProxyPortBox" Grid.Column="1" Margin="14,0,0,0" Text="1080" MaxLength="5" />
                        </Grid>

                        <Grid Grid.Row="5" Margin="0,0,0,7">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="密码" FontSize="13" FontWeight="SemiBold" />
                            <CheckBox x:Name="ShowPasswordCheckBox" Grid.Column="1" Content="显示密码" Checked="ShowPassword_Checked" Unchecked="ShowPassword_Unchecked" />
                        </Grid>
                        <Grid Grid.Row="6" Margin="0,0,0,18">
                            <PasswordBox x:Name="PasswordInput" AutomationProperties.AutomationId="PasswordInput" PasswordChanged="PasswordInput_PasswordChanged" />
                            <TextBox x:Name="VisiblePasswordInput" AutomationProperties.AutomationId="VisiblePasswordInput" Visibility="Collapsed" TextChanged="VisiblePasswordInput_TextChanged" />
                        </Grid>

                        <TextBlock x:Name="ValidationText" Grid.Row="7" Foreground="{StaticResource DangerBrush}" Visibility="Collapsed" Margin="0,0,0,14" />

                        <Grid Grid.Row="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="SaveButton" AutomationProperties.AutomationId="SaveButton" AutomationProperties.Name="保存配置" Style="{StaticResource SecondaryButton}" Click="SaveButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE74E;" FontFamily="Segoe Fluent Icons" Margin="0,0,8,0" />
                                    <TextBlock Text="保存配置" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="ConnectButton" AutomationProperties.AutomationId="ConnectButton" AutomationProperties.Name="连接或断开" Grid.Column="2" Style="{StaticResource PrimaryButton}" Click="ConnectButton_Click" MinWidth="112">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="ConnectButtonIcon" Text="&#xE768;" FontFamily="Segoe Fluent Icons" Margin="0,0,8,0" />
                                    <TextBlock x:Name="ConnectButtonText" Text="连接" Foreground="White" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="LogTab" Header="日志">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="运行日志" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Grid.Column="1" AutomationProperties.AutomationId="CopyLogsButton" AutomationProperties.Name="复制日志" Style="{StaticResource SecondaryButton}" Height="32" Padding="12,0" Margin="0,0,8,0" Click="CopyLogsButton_Click" ToolTip="复制全部日志">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8C8;" FontFamily="Segoe Fluent Icons" Margin="0,0,7,0" />
                                <TextBlock Text="复制" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2" AutomationProperties.AutomationId="ClearLogsButton" AutomationProperties.Name="清空日志" Style="{StaticResource SecondaryButton}" Height="32" Padding="12,0" Click="ClearLogsButton_Click" ToolTip="清空日志">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74D;" FontFamily="Segoe Fluent Icons" Margin="0,0,7,0" />
                                <TextBlock Text="清空" />
                            </StackPanel>
                        </Button>
                    </Grid>
                    <ListBox x:Name="LogList"
                             AutomationProperties.AutomationId="LogList"
                             Grid.Row="1"
                             FontFamily="Cascadia Mono, Consolas"
                             FontSize="13"
                             Background="#121A1D"
                             Foreground="#E4EEF0"
                             BorderThickness="0"
                             Padding="8"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             VirtualizingPanel.IsVirtualizing="True">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="7,4" />
                                <Setter Property="Margin" Value="0,1" />
                                <Setter Property="Foreground" Value="#E4EEF0" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           Foreground="#E4EEF0"
                                           FontFamily="Cascadia Mono, Consolas"
                                           FontSize="13"
                                           LineHeight="20"
                                           TextWrapping="Wrap" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="24,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="目录" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,10,0" />
                <TextBlock x:Name="DataDirectoryText" Grid.Column="1" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
                <Button Grid.Column="2" AutomationProperties.AutomationId="OpenDirectoryButton" AutomationProperties.Name="打开程序目录" Style="{StaticResource SecondaryButton}" Height="30" Padding="10,0" Click="OpenDirectoryButton_Click" ToolTip="打开程序目录">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8B7;" FontFamily="Segoe Fluent Icons" Margin="0,0,7,0" />
                        <TextBlock Text="打开目录" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
